  exportFailedText: "\u3046\u307E\u304F\u3044\u304B\u306A\u304B\u3063\u305F\u307F\u305F\u3044\u3000\u3054\u3081\u3093\u306D"
  qrCaption: "\u304A\u3046\u3061\u3067\u3082\u307F\u3048\u308B\u3088\u3046\u306B\u3000\u307B\u305E\u3093\u3057\u3066\u306D"
  crowdText: "\u3058\u3085\u3046\u305F\u3093\u306E\u3046\u3048\u306F\u3000\u3072\u3068\u308A\u3060\u3051\u3000\u306B\u3057\u3066\u306D"
  consentText: "\u3053\u306E\u3055\u304F\u3072\u3093\u306F\n\u30A4\u30F3\u30BF\u30FC\u30CD\u30C3\u30C8\u3067\u3000\u307F\u3089\u308C\u308B\u3088\u3046\u306B\u3000\u306A\u308A\u307E\u3059\u3002\n\n\u305D\u308C\u304C\u3000\u3044\u3084\u306A\u3072\u3068\u306F\u3000\u305F\u3044\u3051\u3093\u304C\u3000\u3067\u304D\u306A\u3044\u306E\u3067\n\u30AB\u30FC\u30DA\u30C3\u30C8\u306E\u3000\u305D\u3068\u306B\u3000\u3067\u3066\u306D\u3002"
  welcomeText: "\u3088\u3046\u3053\u305D\u3001\u304B\u3089\u3060\u3092\u3064\u304B\u3063\u3066\u3000\n\u304A\u3082\u3057\u308D\u3044\u304B\u305F\u3061\u304C\u3000\u3064\u304F\u308C\u308B\u3088"
