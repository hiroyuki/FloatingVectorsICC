  calibrateMatchedText: "\u306F\u304B\u308C\u305F\u3088\uFF01"
  testMove1IntroText: "\u3058\u3076\u3093\u306E\u3000\u3046\u3054\u304D\u3092\n\u3068\u308B\u308C\u3093\u3057\u3085\u3046\u3092\u3000\u3057\u3088\u3046"
  testMove1Intro2Text: "\uFF15\u3073\u3087\u3046\u305F\u3063\u305F\u3089\n\uFF11\u3073\u3087\u3046\u304B\u3093\u3000\u3068\u308B\u3088\n\u305F\u304F\u3055\u3093\u3000\u3046\u3054\u3044\u3066\u306D"
  testMove2IntroText: "\u3069\u3046\u3060\u3063\u305F\uFF1F\n\u3082\u3046\u3044\u3061\u3069\u3000\u308C\u3093\u3057\u3085\u3046\u3059\u308B\u3088"
